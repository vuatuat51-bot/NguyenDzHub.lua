-- ===== VÒNG LẶP ÉP TỐC ĐỘ CHẠY & CORE QUÉT SÂU QUÁI VẬT TOÀN DIỆN =====
local espInterval = 0.4
local lastEspTime = 0

RunService.Heartbeat:Connect(function()
    local now = tick()
    
    -- [1] ÉP TỐC ĐỘ LIÊN TỤC (ĐÃ FIX SLIDER CŨ)
    if char and humanoid and not Settings.flying then 
        pcall(function() 
            if humanoid.WalkSpeed ~= Settings.CustomSpeed then
                humanoid.WalkSpeed = Settings.CustomSpeed
            end
            if humanoid.UseJumpPower == false then
                humanoid.UseJumpPower = true
            end
        end) 
    end
    
    -- Anti Stun Tweak
    if Settings.antiStun and humanoid then 
        pcall(function()
            if humanoid.PlatformStand then humanoid.PlatformStand = false end
            if humanoid:GetState() == Enum.HumanoidStateType.Ragdoll then 
                humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) 
            end
        end) 
    end
    
    -- [2] LUỒNG TRÍ TUỆ NHÂN TẠO QUÉT ESP KHÔNG SÓT MỤC TIÊU
    if now - lastEspTime >= espInterval then
        lastEspTime = now
        
        -- Nếu tắt hết trên menu, giải phóng toàn bộ tài nguyên ngay lập tức để tăng FPS
        if not Settings.espEnabled and not Settings.npcEspEnabled and not Settings.itemEspEnabled then
            ClearAllESP()
            return
        end
        
        pcall(function()
            -- Quét sâu tận gốc rễ của Game
            for _, obj in ipairs(workspace:GetDescendants()) do
                
                -- ĐIỀU KIỆN LỌC MODEL GỐC: Chỉ xử lý Model thực thể, bỏ qua bản thân người dùng
                if obj:IsA("Model") and obj ~= char and obj.Parent then
                    
                    -- Lấy thông tin người chơi (nếu có) để phân loại với NPC
                    local isPlayer = Players:GetPlayerFromCharacter(obj)
                    local hum = obj:FindFirstChildOfClass("Humanoid")
                    
                    -- 🔴 KIỂM TRA & SỬA LỖI ESP NPC (QUÁI VẬT TRỐN TRONG THƯ MỤC ẨN)
                    if Settings.npcEspEnabled and hum and hum.Health > 0 and not isPlayer then
                        -- Kiểm tra lớp bọc: Nếu Model cha của nó cũng là một Model có Humanoid thì bỏ qua để tránh trùng tag
                        local parentModel = obj.Parent:IsA("Model") and obj.Parent:FindFirstChildOfClass("Humanoid")
                        if not parentModel then
                            CreateESP(obj, Color3.fromRGB(255, 50, 50), false) -- Chấm Đỏ cho NPC
                        end
                    end
                    
                    -- 🟢 KIỂM TRA ESP NGƯỜI CHƠI KHÁC
                    if Settings.espEnabled and isPlayer and isPlayer ~= player and hum and hum.Health > 0 then
                        CreateESP(obj, Color3.fromRGB(0, 255, 100), false) -- Chấm Xanh cho Player
                    end
                
                -- 🔵 KIỂM TRA ESP VẬT PHẨM (ITEMS / TOOLS)
                elseif Settings.itemEspEnabled and obj:IsA("Tool") then
                    local handle = obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart")
                    if handle then 
                        CreateESP(obj, Color3.fromRGB(0, 150, 255), true) -- Chấm Xanh Dương cho Vật phẩm
                    end
                end
            end
        end)
    end
end)

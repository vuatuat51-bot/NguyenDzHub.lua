local ThemeColor = Color3.fromRGB(255, 50, 50) 
local ObjectsToTheme = {}

local function UpdateTheme(newColor)
	ThemeColor = newColor
	for obj, prop in pairs(ObjectsToTheme) do
		if obj and obj.Parent then
			obj[prop] = newColor
		else
			ObjectsToTheme[obj] = nil
		end
	end
end


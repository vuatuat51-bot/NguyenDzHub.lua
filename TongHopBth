local noclipParts = {}
RunService.Stepped:Connect(function() 
    if Settings.noclip and char then 
        for _, part in ipairs(char:GetDescendants()) do 
            if part:IsA("BasePart") and part.CanCollide then noclipParts[part] = true; part.CanCollide = false end 
        end 
    elseif not Settings.noclip then
        for part in pairs(noclipParts) do if part and part.Parent then part.CanCollide = true end end
        table.clear(noclipParts)
    end
end)

-- ===== VÒNG LẶP TRAFFIC CHÍNH =====
local espInterval = 0.4
local lastEspTime = 0

RunService.Heartbeat:Connect(function()
    local now = tick()
    
    if humanoid and char and not Settings.flying then 
        pcall(function() if humanoid.WalkSpeed ~= Settings.CustomSpeed then humanoid.WalkSpeed = Settings.CustomSpeed end end) 
    end
    
    if Settings.antiStun and humanoid then 
        pcall(function()
            if humanoid.PlatformStand then humanoid.PlatformStand = false end
            if humanoid:GetState() == Enum.HumanoidStateType.Ragdoll then humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end
        end) 
    end
    
    if now - lastEspTime >= espInterval then
        lastEspTime = now
        if not Settings.espEnabled and not Settings.npcEspEnabled and not Settings.itemEspEnabled then ClearAllESP() return end
        
        -- Dọn dẹp ESP cũ không còn thực thể hợp lệ (ngăn kẹt hình khi chết/rời map)
        for id, data in pairs(espObjects) do
            if not data.root or not data.root.Parent or not data.root.Parent.Parent then
                pcall(function() if data.box then data.box:Destroy() end end)
                pcall(function() if data.billboard then data.billboard:Destroy() end end)
                espObjects[id] = nil
            end
        end
        
        if Settings.espEnabled then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and p.Character then CreateESP(p.Character, Color3.fromRGB(0, 255, 0), false) end
            end
        end
        
        if Settings.npcEspEnabled then
            for _, n in ipairs(workspace:GetChildren()) do
                if n:IsA("Model") and n:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(n) then
                    CreateESP(n, Color3.fromRGB(255, 0, 0), false)
                end
            end
        end
        
        if Settings.itemEspEnabled then
            for _, n in ipairs(workspace:GetChildren()) do
                if n:IsA("Tool") or (n:IsA("Model") and not n:FindFirstChildOfClass("Humanoid")) then
                    CreateESP(n, Color3.fromRGB(0, 100, 255), true)
                end
            end
        end
    end
end)

-- ===== ENGINE FLY ĐA NỀN TẢNG (RENDER STEP) =====
RunService.RenderStepped:Connect(function()
    local cam = workspace.CurrentCamera
    if Settings.flying and flyBodyVelocity and flyBodyGyro and char and char:FindFirstChild("HumanoidRootPart") then 
        pcall(function()
            local moveDir = Vector3.new(0, 0, 0)
            
            if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir = moveDir - Vector3.new(0, 1, 0) end
            
            if mobileFlyUp then moveDir = moveDir + Vector3.new(0, 1, 0) end
            if mobileFlyDown then moveDir = moveDir - Vector3.new(0, 1, 0) end
            
            if humanoid and humanoid.MoveDirection.Magnitude > 0 then
                moveDir = moveDir + humanoid.MoveDirection
            end
            
            flyBodyGyro.CFrame = cam.CFrame
            flyBodyVelocity.velocity = moveDir.Magnitude > 0 and moveDir.Unit * Settings.FlySpeed or Vector3.new(0, 0.1, 0)
        end) 
    end
    if Settings.fullbright then pcall(function() Lighting.Ambient = Color3.fromRGB(255, 255, 255) end) end
end)


-- ==================== VÒNG LẶP HỆ THỐNG (VẬT LÝ & GIAN LẬN) ====================
UIS.JumpRequest:Connect(function()
	if infJump and humanoid then humanoid:ChangeState("Jumping") end
end)

RunService.Stepped:Connect(function()
	if noclip and char then
		for _, part in ipairs(char:GetDescendants()) do
			if part:IsA("BasePart") then part.CanCollide = false end
		end
	end
	-- Logic Chống Choáng & Chống mất máu cơ bản cấp client
	if humanoid then
		if antiStun and humanoid.PlatformStand then humanoid.PlatformStand = false end
		if antiDamage and humanoid.Health < humanoid.MaxHealth then humanoid.Health = humanoid.MaxHealth end
	end
end)

RunService.Heartbeat:Connect(function()
	if humanoid and char and not flying then
		if humanoid.WalkSpeed ~= CustomSpeed then humanoid.WalkSpeed = CustomSpeed end
	end
end)

RunService.RenderStepped:Connect(function()
	if flying and flyVelocity and char then
		local cam = workspace.CurrentCamera
		local moveDir = Vector3.new(0, 0, 0)
		if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cam.CFrame.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cam.CFrame.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir + cam.CFrame.RightVector * -1 end
		if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cam.CFrame.RightVector end
		if moveDir.Magnitude > 0 then
			flyVelocity.VectorVelocity = moveDir.Unit * FlySpeed
		else
			flyVelocity.VectorVelocity = Vector3.new(0, 0, 0)
		end
	end
end)

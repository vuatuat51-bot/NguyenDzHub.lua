-- Lưu lại kích thước gốc để phục vụ tính năng Scale tỷ lệ
local BaseMenuSize = Vector2.new(560, 360)

-- Hàm xử lý thay đổi độ nhỏ lớn (Scale Engine)
local function ChangeMenuScale(scaleValue)
	MenuScale = math.clamp(scaleValue, 0.6, 1.5) -- Giới hạn thu nhỏ tối đa 60%, phóng to tối đa 150%
	
	-- Tính toán kích thước mới dựa trên tỷ lệ và kích thước gốc
	local newWidth = BaseMenuSize.X * MenuScale
	local newHeight = BaseMenuSize.Y * MenuScale
	
	-- Giữ nguyên tâm Menu khi thay đổi kích thước
	MainMenu.Size = UDim2.new(0, newWidth, 0, newHeight)
	
	-- Tự động co giãn cỡ chữ của các TextLabel/TextButton có trong Menu để không bị vỡ bố cục
	for _, child in ipairs(MainMenu:GetDescendants()) do
		if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
			if not child:GetAttribute("BaseTextSize") then
				child:SetAttribute("BaseTextSize", child.TextSize)
			end
			local baseSize = child:GetAttribute("BaseTextSize")
			child.TextSize = math.clamp(math.round(baseSize * MenuScale), 8, 32)
		end
	end
end


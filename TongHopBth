local function ToggleFly(state)
    Settings.flying = state
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    if state then
        pcall(function()
            if flyBodyGyro then flyBodyGyro:Destroy() end
            if flyBodyVelocity then flyBodyVelocity:Destroy() end
            
            flyBodyGyro = Instance.new("BodyGyro", hrp)
            flyBodyGyro.P = 9e4
            flyBodyGyro.maxTorque = Vector3.new(9e9, 9e9, 9e9)
            
            flyBodyVelocity = Instance.new("BodyVelocity", hrp)
            flyBodyVelocity.velocity = Vector3.new(0, 0.1, 0)
            flyBodyVelocity.maxForce = Vector3.new(9e9, 9e9, 9e9)
            
            if humanoid then humanoid.PlatformStand = true end
            if isMobile then CreateMobileFlyControls() end
        end)
    else
        if flyBodyGyro then pcall(function() flyBodyGyro:Destroy() end) flyBodyGyro = nil end
        if flyBodyVelocity then pcall(function() flyBodyVelocity:Destroy() end) flyBodyVelocity = nil end
        if humanoid then humanoid.PlatformStand = false end
        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        
        if flyUpBtn then pcall(function() flyUpBtn:Destroy() end) flyUpBtn = nil end
        if flyDownBtn then pcall(function() flyDownBtn:Destroy() end) flyDownBtn = nil end
        mobileFlyUp, mobileFlyDown = false, false
    end
end

-- ===== ANTI-BAN ENGINE =====
local antiBanConnection = nil
local function ToggleAntiBan(state)
    Settings.antiBan = state
    if state then
        antiBanConnection = RunService.Heartbeat:Connect(function()
            if char and char:FindFirstChild("HumanoidRootPart") then
                local hrp = char.HumanoidRootPart
                if hrp.AssemblyLinearVelocity.Magnitude > 120 then
                    hrp.AssemblyLinearVelocity = hrp.AssemblyLinearVelocity * 0.3
                end
            end
        end)
    else
        if antiBanConnection then antiBanConnection:Disconnect() antiBanConnection = nil end
    end
end

-- ===== LÕI GODMODE SỬA ĐỔI CHỐNG DIED =====
local godModeConnection = nil
local function ToggleGodMode(state)
    Settings.godMode = state
    if not humanoid then return end
    
    if state then
        humanoid.BreakJointsOnDeath = false
        godModeConnection = humanoid.HealthChanged:Connect(function(health)
            if Settings.godMode and health <= 15 then
                pcall(function()
                    humanoid.Health = humanoid.MaxHealth
                end)
            end
        end)
    else
        humanoid.BreakJointsOnDeath = true
        if godModeConnection then godModeConnection:Disconnect() godModeConnection = nil end
    end
end

-- ===== HỆ THỐNG VẼ ESP AN TOÀN =====
local espObjects = {}
local function CreateESP(v, color, isItem)
    if v == player or not v.Parent then return end
    local root = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChildWhichIsA("BasePart")
    if not root then return end
    
    local espId = tostring(v.Name) .. "_" .. tostring(isItem and "item" or "char")
    if espObjects[espId] then return end
    
    local size = isItem and Vector3.new(1.5, 1.5, 1.5) or Vector3.new(3.8, 5.5, 1)
    
    local box = Instance.new("BoxHandleAdornment")
    box.Name = "HubESP"
    box.AlwaysOnTop = true
    box.ZIndex = 5
    box.Adornee = root
    box.Color3 = color
    box.Size = size
    box.Transparency = 0.5
    box.Parent = root
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "HubESPName"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 120, 0, 25)
    billboard.SizeOffset = Vector2.new(0, size.Y/2 + 0.5)
    billboard.Parent = root
    
    local tag = Instance.new("TextLabel", billboard)
    tag.Size = UDim2.new(1, 0, 1, 0)
    tag.BackgroundTransparency = 1
    tag.Text = v.Name
    tag.TextColor3 = color
    tag.Font = Enum.Font.SourceSansBold
    tag.TextSize = 13
    tag.TextStrokeTransparency = 0.3
    
    espObjects[espId] = {box = box, billboard = billboard, root = root}
end

local function ClearAllESP()
    for id, data in pairs(espObjects) do
        pcall(function() if data.box then data.box:Destroy() end end)
        pcall(function() if data.billboard then data.billboard:Destroy() end end)
    end
    table.clear(espObjects)
end

-- ===== THIẾT KẾ KHUNG KÉO THẢ =====
local function MakeDraggable(gui)
    local dragging, dragStart, startPos
    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = gui.Position
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            gui.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
end


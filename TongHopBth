	local TabBtn = Instance.new("TextButton")
	TabBtn.Size = UDim2.new(1, 0, 0, 35)
	TabBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
	TabBtn.BackgroundTransparency = 1

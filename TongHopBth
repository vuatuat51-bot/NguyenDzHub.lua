			hrp.AssemblyLinearVelocity = Vector3.new(0,0,0) -- Xóa gia tốc thực tế liên tục
		else
			if humanoid then pcall(function() humanoid.WalkSpeed = CustomSpeed end) end
		end
	end
	
	-- Anti Stun Engine
	if antiStun and humanoid then 
		pcall(function()
			if humanoid.PlatformStand and not flying then humanoid.PlatformStand = false end
			if humanoid:GetState() == Enum.HumanoidStateType.Ragdoll then humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end
		end) 
	end
	
	-- Tính năng Godmode Chế độ 2 (Camouflage Void)
	if godMode2 and humanoid and char and char:FindFirstChild("HumanoidRootPart") then
		pcall(function()
			if humanoid.Health < (humanoid.MaxHealth * 0.2) and humanoid.Health > 0 then
				local hrp = char.HumanoidRootPart
				local oldCFrame = hrp.CFrame
				-- Giấu tạm thời xuống lòng đất để tự hồi máu ngoài tầm đánh
				hrp.CFrame = oldCFrame * CFrame.new(0, -500, 0)
				task.wait(0.3)
				hrp.CFrame = oldCFrame
			end
		end)
	end
	
	-- Vòng lặp quét hệ thống ESP
	for _, p in ipairs(Players:GetPlayers()) do
		local pc = p.Character; local hrp = pc and pc:FindFirstChild("HumanoidRootPart")
		if espEnabled then if hrp then ApplyESP(pc, Color3.fromRGB(0, 255, 120), false) end else CleanESP(hrp) end
	end
	
	for _, n in ipairs(workspace:GetChildren()) do
		local nhrp = n:FindFirstChild("HumanoidRootPart")
		if n:IsA("Model") and n:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(n) then
			if npcEspEnabled then if nhrp then ApplyESP(n, Color3.fromRGB(255, 60, 60), false) end else CleanESP(nhrp) end
		end
	end
	
	for _, n in ipairs(workspace:GetDescendants()) do
		if n:IsA("Tool") or (n:IsA("Model") and not n:FindFirstChildOfClass("Humanoid")) then
			local itemPart = n:FindFirstChildWhichIsA("BasePart") or (n:IsA("Tool") and n:FindFirstChild("Handle"))
			if itemEspEnabled then if itemPart then ApplyESP(n, Color3.fromRGB(255, 215, 0), true) end else CleanESP(itemPart) end
		end
	end
end)

-- VÒNG LẶP ENGINE BAY BẰNG CAMERA BYPASS (RenderStepped)
RunService.RenderStepped:Connect(function()
	local cam = workspace.CurrentCamera
	if flying and flyLinearVelocity and char and char:FindFirstChild("HumanoidRootPart") then 
		pcall(function()
			local moveDir = Vector3.new(0, 0, 0)
			if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cam.CFrame.LookVector end
			if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cam.CFrame.LookVector end
			if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - cam.CFrame.RightVector end
			if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cam.CFrame.RightVector end
			if UIS:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
			if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir = moveDir - Vector3.new(0, 1, 0) end
			
			-- Cập nhật trực tiếp VectorVelocity mượt mà không đẩy xung vật lý thực
			flyLinearVelocity.VectorVelocity = moveDir.Magnitude > 0 and moveDir.Unit * FlySpeed or Vector3.new(0, 0.1, 0)
			char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
		end) 
	end
	if fullbright then pcall(function() Lighting.Ambient = Color3.fromRGB(255, 255, 255) end) end
end)


-- ===== VÒNG LẶP ÉP TỐC ĐỘ CHẠY & HỆ THỐNG ESP SMART QUÉT SÂU TRÚT SẠCH LỖI =====
local espInterval = 0.4
local lastEspTime = 0

RunService.Heartbeat:Connect(function()
    local now = tick()
    
    -- FIX TỐC ĐỘ: Ép mạnh từng khung hình tránh anti-cheat của game reset
    if char and humanoid and not Settings.flying then 
        pcall(function() 
            if humanoid.WalkSpeed ~= Settings.CustomSpeed then
                humanoid.WalkSpeed = Settings.CustomSpeed
            end
            if humanoid.UseJumpPower == false then
                humanoid.UseJumpPower = true
            end
        end) 
    end
    
    -- Anti Stun Tweak
    if Settings.antiStun and humanoid then 
        pcall(function()
            if humanoid.PlatformStand then humanoid.PlatformStand = false end
            if humanoid:GetState() == Enum.HumanoidStateType.Ragdoll then 
                humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) 
            end
        end) 
    end
    
    -- XỬ LÝ HỆ THỐNG VÒNG LẶP ESP SMART DOT
    if now - lastEspTime >= espInterval then
        lastEspTime = now
        
        -- Nếu tắt hết trên menu thì chặn đứng ngắt luồng ngay lập tức để cứu FPS
        if not Settings.espEnabled and not Settings.npcEspEnabled and not Settings.itemEspEnabled then
            ClearAllESP()
            return
        end
        
        pcall(function()
            -- Quét sâu toàn bộ thư mục trong Workspace để lôi quái ra ánh sáng
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Model") and obj ~= char then
                    
                    -- 🔴 FIX LỖI ESP NPC (QUÁI VẬT): Lọc chuẩn xác sâu chuỗi thư mục ẩn
                    if Settings.npcEspEnabled then
                        local hum = obj:FindFirstChildOfClass("Humanoid")
                        if hum and hum.Health > 0 then
                            local isPlayer = Players:GetPlayerFromCharacter(obj)
                            if not isPlayer then
                                CreateESP(obj, Color3.fromRGB(255, 50, 50), false)
                            end
                        end
                    end
                    
                    -- 🟢 ESP NGƯỜI CHƠI
                    if Settings.espEnabled then
                        local isPlayer = Players:GetPlayerFromCharacter(obj)
                        if isPlayer and isPlayer ~= player then
                            local hum = obj:FindFirstChildOfClass("Humanoid")
                            if hum and hum.Health > 0 then
                                CreateESP(obj, Color3.fromRGB(0, 255, 100), false)
                            end
                        end
                    end
                
                -- 🔵 ESP VẬT PHẨM
                elseif Settings.itemEspEnabled then
                    if obj:IsA("Tool") then
                        local handle = obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart")
                        if handle then CreateESP(obj, Color3.fromRGB(0, 150, 255), true) end
                    end
                end
            end
        end)
    end
end)

-- ===== ENGINE BAY HOÀN TOÀN THEO HƯỚNG CAM (ĐÃ FIX LỖI NGƯỢC & LÙI THÀNH NGANG) =====
RunService.RenderStepped:Connect(function()
    if Settings.flying and flyBodyVelocity and flyBodyGyro and char and char:FindFirstChild("HumanoidRootPart") then 
        pcall(function()
            local moveDir = Vector3.new(0, 0, 0)
            
            flyBodyGyro.CFrame = camera.CFrame
            
            -- Kiểm tra nguồn di chuyển từ PC hay Mobile để tính toán Vector lực đẩy chuẩn xác
            local isKeyboardMoving = UIS:IsKeyDown(Enum.KeyCode.W) or UIS:IsKeyDown(Enum.KeyCode.S) or UIS:IsKeyDown(Enum.KeyCode.A) or UIS:IsKeyDown(Enum.KeyCode.D)
            
            if isKeyboardMoving then
                -- Ép lực đẩy trùng khít hoàn toàn hướng nhìn Cam, không đấm nhau loạn hướng
                if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camera.CFrame.RightVector end
            elseif humanoid and humanoid.MoveDirection.Magnitude > 0 then
                -- Di chuyển cho điện thoại mượt mà thông qua Joystick ảo
                moveDir = humanoid.MoveDirection
            end
            
            if UIS:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir = moveDir - Vector3.new(0, 1, 0) end
            
            if moveDir.Magnitude > 0 then
                flyBodyVelocity.velocity = moveDir.Unit * Settings.FlySpeed
            else
                flyBodyVelocity.velocity = Vector3.new(0, 0.1, 0)
            end
        end) 
    end
    if Settings.fullbright then pcall(function() Lighting.Ambient = Color3.fromRGB(255, 255, 255) end) end
end)


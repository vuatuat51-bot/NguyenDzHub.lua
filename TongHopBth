-- Lõi Xử lý Vẽ ESP
local function ApplyESP(v, color, isItem)
	if v == player or not v.Parent then return end
	local root = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChildWhichIsA("BasePart")
	if not root or root:FindFirstChild("HubESP") then return end
	
	local box = Instance.new("BoxHandleAdornment", root)
	box.Name = "HubESP"; box.AlwaysOnTop = true; box.ZIndex = 5; box.Adornee = root; box.Color3 = color
	box.Size = isItem and Vector3.new(1.4, 1.4, 1.4) or Vector3.new(3.8, 5.2, 1); box.Transparency = 0.55
	
	local billboard = Instance.new("BillboardGui", root)
	billboard.Name = "HubESPName"; billboard.AlwaysOnTop = true; billboard.Size = UDim2.new(0, 100, 0, 20); billboard.SizeOffset = Vector2.new(0, 2)
	local tag = Instance.new("TextLabel", billboard)
	tag.Size = UDim2.new(1, 0, 1, 0); tag.BackgroundTransparency = 1; tag.Text = v.Name; tag.TextColor3 = color; tag.Font = Enum.Font.SourceSansBold; tag.TextSize = 12
	tag.TextStrokeTransparency = 0.5; tag.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
end

local function CleanESP(root)
	if root then
		local b = root:FindFirstChild("HubESP") local n = root:FindFirstChild("HubESPName")
		if b then b:Destroy() end if n then n:Destroy() end
	end
end


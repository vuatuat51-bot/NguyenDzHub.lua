local function CreateSliderRow(page, featureText, min, max, default, callback)
	local Row = Instance.new("Frame")
	Row.Size = UDim2.new(1, -10, 0, 45)
	Row.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
	Row.BackgroundTransparency = 0.3
	Row.Parent = page
	Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 6)

	local Label = Instance.new("TextLabel")
	Label.Size = UDim2.new(0.4, 0, 1, 0)
	Label.Position = UDim2.new(0, 12, 0, 0)
	Label.BackgroundTransparency = 1
	Label.Text = featureText .. " (" .. string.format("%.1f", default) .. "x)"
	Label.TextColor3 = Color3.fromRGB(210, 210, 215)
	Label.Font = Enum.Font.SourceSans
	Label.TextSize = 14
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = Row

	local SliderContainer = Instance.new("Frame")
	SliderContainer.Size = UDim2.new(0, 120, 0, 6)
	SliderContainer.Position = UDim2.new(1, -140, 0, 20)
	SliderContainer.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
	SliderContainer.Parent = Row

	local SliderFill = Instance.new("Frame")
	SliderFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
	SliderFill.BackgroundColor3 = ThemeColor
	SliderFill.Parent = SliderContainer
	ObjectsToTheme[SliderFill] = "BackgroundColor3"

	local SliderButton = Instance.new("TextButton")
	SliderButton.Size = UDim2.new(0, 14, 0, 14)
	SliderButton.Position = UDim2.new((default - min) / (max - min), -7, 0, -4)
	SliderButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	SliderButton.Text = ""
	SliderButton.Parent = SliderContainer
	Instance.new("UICorner", SliderButton).CornerRadius = UDim.new(0, 7)

	local isSliding = false
	local function UpdateSlider(inputPosition)
		local percentage = math.clamp((inputPosition.X - SliderContainer.AbsolutePosition.X) / SliderContainer.AbsoluteSize.X, 0, 1)
		SliderFill.Size = UDim2.new(percentage, 0, 1, 0)
		SliderButton.Position = UDim2.new(percentage, -7, 0, -4)
		local realValue = min + (percentage * (max - min))
		Label.Text = featureText .. " (" .. string.format("%.1f", realValue) .. "x)"
		callback(realValue)
	end
	SliderButton.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isSliding = true end end)
	UIS.InputChanged:Connect(function(input) if isSliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then UpdateSlider(input.Position) end end)
	UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isSliding = false end end)
end


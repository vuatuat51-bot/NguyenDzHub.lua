-- ==================== HỆ THỐNG ANTI-BAN (BYPASS ANTI-CHEAT) ====================
local function InitiateAntiBan()
	local gmt = getrawmetatable(game)
	if gmt and setreadonly then
		setreadonly(gmt, false)
		local oldNamecall = gmt.__namecall
		local oldIndex = gmt.__index

		gmt.__namecall = newcclosure(function(self, ...)
			local method = getnamecallmethod()
			if not checkcaller() then
				if method == "Kick" or method == "kick" then
					return nil
				elseif method == "FireServer" and self.Name:lower():find("cheat") then
					return nil
				end
			end
			return oldNamecall(self, ...)
		end)

		gmt.__index = newcclosure(function(self, property)
			if not checkcaller() and self:IsA("Humanoid") then
				if property == "WalkSpeed" then
					return 16
				elseif property == "JumpPower" then
					return 50
				elseif property == "PlatformStand" then
					return false
				end
			end
			return oldIndex(self, property)
		end)
		setreadonly(gmt, true)
	end
end
pcall(InitiateAntiBan)


-- Hệ thống ESP Xuyên tường người chơi
local espHighlights = {}
local function applyESP()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			if espEnabled then
				if not espHighlights[p] then
					local hi = Instance.new("Highlight")
					hi.Name = "ESP_NguyenDz"
					hi.FillColor = Color3.fromRGB(255, 0, 0)
					hi.FillTransparency = 0.5
					hi.OutlineColor = Color3.fromRGB(255, 255, 255)
					hi.OutlineTransparency = 0
					hi.Adornee = p.Character
					hi.Parent = ScreenGui
					espHighlights[p] = hi
				end
			else
				if espHighlights[p] then espHighlights[p]:Destroy() espHighlights[p] = nil end
			end
		end
	end
end

CreateToggleRow(MainTab, "Nhìn xuyên tường (Player ESP)", false, function(state)
	espEnabled = state
	applyESP()
end)

Players.PlayerAdded:Connect(function(p)
	p.CharacterAdded:Connect(function() task.wait(0.5) if espEnabled then applyESP() end end)
end)
Players.PlayerRemoving:Connect(function(p) if espHighlights[p] then espHighlights[p]:Destroy() espHighlights[p] = nil end end)


local function CreateToggleRow(page, featureText, defaultState, callback)
	local Row = Instance.new("Frame")
	Row.Size = UDim2.new(1, -10, 0, 40)
	Row.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
	Row.BackgroundTransparency = 0.3
	Row.BorderSizePixel = 0
	Row.Parent = page
	Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 6)

	local Label = Instance.new("TextLabel")
	Label.Size = UDim2.new(0.7, 0, 1, 0)
	Label.Position = UDim2.new(0, 12, 0, 0)
	Label.BackgroundTransparency = 1
	Label.Text = featureText
	Label.TextColor3 = Color3.fromRGB(210, 210, 215)
	Label.Font = Enum.Font.SourceSans
	Label.TextSize = 14
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = Row

	local ToggleBtn = Instance.new("TextButton")
	ToggleBtn.Size = UDim2.new(0, 45, 0, 22)
	ToggleBtn.Position = UDim2.new(1, -55, 0, 9)
	ToggleBtn.BackgroundColor3 = defaultState and ThemeColor or Color3.fromRGB(50, 50, 55)
	ToggleBtn.Text = ""
	ToggleBtn.Parent = Row
	Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(0, 11)
	if defaultState then ObjectsToTheme[ToggleBtn] = "BackgroundColor3" end

	local StateCircle = Instance.new("Frame")
	StateCircle.Size = UDim2.new(0, 16, 0, 16)
	StateCircle.Position = defaultState and UDim2.new(1, -20, 0, 3) or UDim2.new(0, 4, 0, 3)
	StateCircle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	StateCircle.Parent = ToggleBtn
	Instance.new("UICorner", StateCircle).CornerRadius = UDim.new(0, 8)

	local active = defaultState
	
	local function updateVisuals()
		if active then
			ObjectsToTheme[ToggleBtn] = "BackgroundColor3"
			TweenService:Create(ToggleBtn, TweenInfo.new(0.15), {BackgroundColor3 = ThemeColor}):Play()
			TweenService:Create(StateCircle, TweenInfo.new(0.15), {Position = UDim2.new(1, -20, 0, 3)}):Play()
		else
			ObjectsToTheme[ToggleBtn] = nil
			TweenService:Create(ToggleBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(50, 50, 55)}):Play()
			TweenService:Create(StateCircle, TweenInfo.new(0.15), {Position = UDim2.new(0, 4, 0, 3)}):Play()
		end
	end

	ToggleBtn.MouseButton1Click:Connect(function()
		active = not active
		callback(active)
		updateVisuals()
	end)
	
	return function(forceState)
		active = forceState
		callback(active)
		updateVisuals()
	end
end


-- ===== HỆ THỐNG VÈ ESP QUÉT THÂN NHIỆT (FIX LỖI NPC TRÙNG LẶP / MẤT DẤU CHẤM) =====
local espObjects = {} -- Sử dụng Object làm Key thay vì dùng chuỗi String tên

local function CreateESP(v, color, isItem)
    if not v or not v.Parent then return end
    
    -- Lấy phần thân gốc chuẩn xác nhất để gắn ESP
    local root = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChildWhichIsA("BasePart")
    if not root then return end
    
    -- Kiểm tra trùng lặp: Nếu thực thể này đang có ESP rồi thì bỏ qua
    if espObjects[v] then return end 
    
    local espFolder = Instance.new("Folder")
    espFolder.Name = "PureESP_" .. tostring(v.Name)
    espFolder.Parent = root
    
    -- Tạo dấu chấm tròn nhỏ gọn tại tâm thực thể
    local dot = Instance.new("BoxHandleAdornment")
    dot.Name = "HubDot"
    dot.AlwaysOnTop = true
    dot.ZIndex = 5
    dot.Adornee = root
    dot.Color3 = color
    dot.Size = Vector3.new(0.5, 0.5, 0.5) -- Tăng nhẹ kích thước để nhìn rõ hơn
    dot.Transparency = 0
    dot.Parent = espFolder
    
    -- Tạo nhãn chữ hiển thị Tên
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "HubDotName"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 140, 0, 25)
    billboard.ExtentsOffset = Vector3.new(0, 1.5, 0)
    billboard.Parent = espFolder
    
    local tag = Instance.new("TextLabel", billboard)
    tag.Size = UDim2.new(1, 0, 1, 0)
    tag.BackgroundTransparency = 1
    tag.Text = v.Name
    tag.TextColor3 = color
    tag.Font = Enum.Font.SourceSansBold
    tag.TextSize = 13
    tag.TextStrokeTransparency = 0.15
    tag.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    
    -- Lưu trữ liên kết trực tiếp bằng Object
    espObjects[v] = espFolder
    
    -- HỆ THỐNG DỌN DẸP TUYỆT ĐỐI CHỐNG LỖI STREAMINGENABLED
    local disconnectAll
    local connDied, connAncestry, connDestroying
    
    disconnectAll = function()
        if connDied then connDied:Disconnect() end
        if connAncestry then connAncestry:Disconnect() end
        if connDestroying then connDestroying:Disconnect() end
        pcall(function() espFolder:Destroy() end)
        espObjects[v] = nil
    end
    
    -- 1. Khi NPC chết hẳn
    local hum = v:FindFirstChildOfClass("Humanoid")
    if hum then
        connDied = hum.Died:Connect(disconnectAll)
    end
    -- 2. Khi NPC bị dịch chuyển ra khỏi Workspace (Xóa tạm thời do đi xa)
    connAncestry = v.AncestryChanged:Connect(function(_, parent)
        if not parent then disconnectAll() end
    end)
    -- 3. Khi thực thể bị hủy hoàn toàn từ Server
    connDestroying = v.Destroying:Connect(disconnectAll)
end

local function ClearAllESP()
    for obj, folder in pairs(espObjects) do
        pcall(function() folder:Destroy() end)
    end
    table.clear(espObjects)
end


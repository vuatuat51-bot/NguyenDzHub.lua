local OpenMenuBtn = Instance.new("TextButton")
OpenMenuBtn.Parent = ScreenGui
OpenMenuBtn.Size = UDim2.new(0, 44, 0, 44)
OpenMenuBtn.Position = UDim2.new(0, 15, 0.4, 0)
OpenMenuBtn.BackgroundColor3 = Color3.fromRGB(24, 24, 28)

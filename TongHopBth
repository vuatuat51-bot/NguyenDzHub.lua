-- ===== HỆ THỐNG VẼ ESP BAO HÌNH DẠNG (BẢN NÂNG CẤP MỚI) =====
local espObjects = {}

local function CreateESP(v, color, isItem)
    if v == player or not v.Parent then return end
    
    -- Tìm root part
    local root = v:FindFirstChild("HumanoidRootPart")
    if not root then
        root = v:FindFirstChildWhichIsA("BasePart")
        if not root then return end
    end
    
    local espId = tostring(v) .. "_" .. tostring(isItem)
    if espObjects[espId] then return end
    
    -- Tính kích thước dựa trên hình dáng thực tế
    local size = Vector3.new(3.8, 5.2, 1)
    local hum = v:FindFirstChildOfClass("Humanoid")
    
    if hum then
        -- Lấy kích thước thực từ Humanoid
        local height = hum.HipHeight or 2
        local width = 3.5
        -- Nếu có các bộ phận, đo kích thước thực
        local torso = v:FindFirstChild("UpperTorso") or v:FindFirstChild("Torso")
        if torso then
            width = torso.Size.X * 1.2
            height = height * 1.8
        end
        size = Vector3.new(width, height, 1)
    elseif isItem then
        size = Vector3.new(1.5, 1.5, 1.5)
    end
    
    -- Tạo Box bao quanh toàn bộ model
    local box = Instance.new("BoxHandleAdornment")
    box.Name = "HubESP"
    box.AlwaysOnTop = true
    box.ZIndex = 5
    box.Adornee = root
    box.Color3 = color
    box.Size = size
    box.Transparency = 0.4
    box.Parent = root
    
    -- Tạo tên hiển thị
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "HubESPName"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 120, 0, 25)
    billboard.SizeOffset = Vector2.new(0, size.Y/2 + 1)
    billboard.Parent = root
    
    local tag = Instance.new("TextLabel", billboard)
    tag.Size = UDim2.new(1, 0, 1, 0)
    tag.BackgroundTransparency = 1
    tag.Text = v.Name or "Unknown"
    tag.TextColor3 = color
    tag.Font = Enum.Font.SourceSansBold
    tag.TextSize = 13
    tag.TextStrokeTransparency = 0.3
    tag.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    
    -- Thanh máu cho NPC/Player
    if hum then
        local healthBar = Instance.new("Frame", billboard)
        healthBar.Size = UDim2.new(1, 0, 0.3, 0)
        healthBar.Position = UDim2.new(0, 0, 1, 2)
        healthBar.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        healthBar.BorderSizePixel = 0
        
        local healthFill = Instance.new("Frame", healthBar)
        healthFill.Size = UDim2.new(hum.Health / hum.MaxHealth, 0, 1, 0) -- Khởi tạo lượng máu hiện tại luôn
        healthFill.BackgroundColor3 = Color3.fromRGB(255 * (1 - (hum.Health / hum.MaxHealth)), 255 * (hum.Health / hum.MaxHealth), 0)
        healthFill.BorderSizePixel = 0
        
        local conn
        conn = hum:GetPropertyChangedSignal("Health"):Connect(function()
            pcall(function()
                if not hum or not hum.Parent then conn:Disconnect() return end
                local percent = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                healthFill.Size = UDim2.new(percent, 0, 1, 0)
                healthFill.BackgroundColor3 = Color3.fromRGB(
                    255 * (1 - percent),
                    255 * percent,
                    0
                )
            end)
        end)
    end
    
    espObjects[espId] = {box = box, billboard = billboard}
end

local function ClearAllESP()
    for id, data in pairs(espObjects) do
        pcall(function()
            if data.box then data.box:Destroy() end
            if data.billboard then data.billboard:Destroy() end
        end)
    end
    table.clear(espObjects)
end

